{
  "manifest_version": 3,
  "name": "Product Extractor",
  "version": "1.0",

  "permissions": [
    "scripting"
  ],

  "host_permissions": [
    "https://udupihut.com/*",
    "https://*.udupihut.com/*",
    "http://35.207.199.225:5000/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": [
        "https://udupihut.com/*",
        "https://*.udupihut.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}